APP_NAME=Kamgus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# =============================================================================
# DATABASE — Supabase Postgres (production) or local for dev
# =============================================================================
# Production (Supabase Pooler):
#   DB_CONNECTION=pgsql
#   DB_HOST=aws-1-us-east-1.pooler.supabase.com
#   DB_PORT=5432
#   DB_DATABASE=postgres
#   DB_USERNAME=postgres.<project-ref>
#   DB_PASSWORD=<your-supabase-db-password>
#   DB_SCHEMA=apikamgusv2,public
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=apikamgusv2,public

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# MAIL — Resend via SMTP
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=Info@kamgus.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# =============================================================================
# Storage — Supabase Storage (S3-compatible) for uploads
# =============================================================================
FILESYSTEM_DRIVER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=kamgus-public
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_PUBLIC=kamgus-public
SUPABASE_BUCKET_PRIVATE=kamgus-private

# =============================================================================
# Stripe
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=USD
CASHIER_CURRENCY_LOCALE=nl_BE
CASHIER_LOGGER=stack

# =============================================================================
# Firebase / Push
# =============================================================================
# Path to service account JSON.
# MUST NOT be in storage/app/public/ (publicly accessible).
FIREBASE_PROJECT_ID=kamgus
FIREBASE_CREDENTIALS_PATH=
AUTHENTICATION_KEY_FIREBASE=

# Expo push
AUTHENTICATION_KEY_EXPO=
EXPONENT_PUSH_NOTIFICATION_INTERESTS_STORAGE_DRIVER=apikamgusv2

# =============================================================================
# Yappy v2 (Commerce Integration v1.1.0)
# =============================================================================
YAPPY_V2_CODIGO_SEMILLA=
YAPPY_V2_API_KEY=
YAPPY_V2_SECRET_KEY=

# Yappy v1 legacy (kept until full refactor)
YAPPY_ID_DEL_COMERCIO=
YAPPY_CLAVE_SECRETA=
YAPPY_MODO_DE_PRUEBAS=false
YAPPY_PLUGIN_VERSION=P1.0.0

INVITED_YAPPY_ID_DEL_COMERCIO=
INVITED_YAPPY_CLAVE_SECRETA=
INVITED_YAPPY_MODO_DE_PRUEBAS=false
INVITED_YAPPY_PLUGIN_VERSION=P1.0.0

# =============================================================================
# Pusher
# =============================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
